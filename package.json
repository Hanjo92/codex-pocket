{
  "name": "codex-pocket",
  "version": "1.0.0",
  "private": true,
  "description": "Mobile viewer/controller for a Codex CLI session",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "cli": "node server/cli.js",
    "run": "node server/cli.js run",
    "onboard": "node server/cli.js onboard",
    "doctor": "node server/cli.js doctor",
    "print-env": "node server/cli.js print-env",
    "account:add": "node server/cli.js account add",
    "account:remove": "node server/cli.js account remove",
    "account:list": "node server/cli.js account list",
    "account:set-default": "node server/cli.js account set-default",
    "account:show": "node server/cli.js account show",
    "user:add": "node server/cli.js user add",
    "user:remove": "node server/cli.js user remove",
    "user:list": "node server/cli.js user list",
    "user:set-password": "node server/cli.js user set-password",
    "user:set-mode": "node server/cli.js user set-mode",
    "user:set-role": "node server/cli.js user set-role",
    "user:set-projects": "node server/cli.js user set-projects",
    "user:set-threads": "node server/cli.js user set-threads",
    "user:set-action-threads": "node server/cli.js user set-action-threads",
    "user:clear-scope": "node server/cli.js user clear-scope"
  }
}
